          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="n_us" style="endArrow=block;html=1;fontSize=11;" target="n_ps" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="n_servicio" style="endArrow=block;html=1;fontSize=11;" target="n_ps" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="n_us" style="endArrow=block;html=1;fontSize=11;" target="n_reserva" value="1 : N  (agenda del profesional)">
          <mxGeometry relative="1" x="0.002" y="-27" as="geometry">
            <mxPoint as="offset" />
            <Array as="points">
              <mxPoint x="610" y="940" />
