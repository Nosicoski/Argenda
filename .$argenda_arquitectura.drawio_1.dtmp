        <mxCell id="e5" edge="1" parent="1" source="n_sucursal" style="endArrow=block;html=1;fontSize=11;dashed=1;strokeColor=#534AB7;" target="n_us" value="1 : N  (acceso)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
