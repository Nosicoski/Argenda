          </mxGeometry>
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="n_servicio" style="endArrow=block;html=1;fontSize=11;" target="n_reserva" value="1 : N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="n_cliente" style="endArrow=block;html=1;fontSize=11;strokeColor=#0F6E56;strokeWidth=2;" target="n_reserva" value="1 : N  (crea la reserva)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="n_sucursal" style="endArrow=block;html=1;fontSize=11;" target="n_reserva" value="1 : N">
